nav
  ul.nav-list
    li.list-item.current-user
      .c-profile-menu.ui.left.top.pointing.dropdown
        .avatar.circle
          .initials= current_user.initials
        .menu
          .header
            .main-text= current_user.name
            .sub-text= current_user.email
          .divider
          - if current_user.admin_of?(current_company)
            = link_to boards_path, class: "item" do
              i.soft.external.icon
              | Public View
          = link_to logout_path, class: "item", method: :delete do
            i.soft.sign.out.icon
            | Logout
      
    li.list-item class=("active" if @main_selected == :boards)
      = link_to admin_boards_path, class: "item-link" do
        i.clone.large.icon
        .item-text Boards
    li.list-item class=("active" if @main_selected == :customers )
      = link_to admin_accounts_path, class: "item-link" do
        i.user.circle.large.icon
        .item-text Customers

  .cadet-logo#changelog
    = image_tag "cadet-logo-grey.png", width: 50

coffee:
  $(".ui.dropdown").dropdown({
    action: "select"
    on: "hover"
  })

