.ui.tiny.modal#vote-on-behalf-modal
  .header Add Vote
  .content
    = simple_form_for @post.votes.build, url: board_post_votes_path(@board, @post) do |form|
      .field
        .ui.fluid.search.selection.dropdown.user-list-dropdown
          input type="hidden" name="user_id"
          i.dropdown.icon
          .default.text Select Users
          .menu
            - current_company.customers.each do |user|
              - next unless user
              - next if @post.voters.include?(user)
              .item data-value=user.id
                = render partial: "partials/user", locals: { user: user, size: :small, show_email: true, hide_avatar: true }

      = form.submit "Add Vote", class: "ui small button"

coffee:
  $(".user-list-dropdown").dropdown()

  $("#add-vote-btn").click ->
    $("#vote-on-behalf-modal").modal('show')
