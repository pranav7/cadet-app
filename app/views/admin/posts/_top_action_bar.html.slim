.top-action-bar
  .item
    // Change Status
    = simple_form_for @post, url: admin_board_post_path(@board, @post) do |form|
      select.ui.top.bar.dropdown.status-dropdown name="post[status]" onchange="this.form.submit()"
        option value="" Status
        - Post.statuses.keys.each do |key|
          option value=key
            | ##{key}
  .item
    a#edit-post-btn
      i.edit.large.icon
  .item
    = link_to admin_board_post_path(@board, @post),
      method: :delete,
      data: { confirm: "Are you sure you want to delete this post? Please note that this step is irreversible." } do
      i.trash.outline.large.icon#delete-icon
  .item
    .ui.left.top.pointing.dropdown.top-bar-more-options
      i.ellipsis.horizontal.large.icon
      .menu
        .item
          span#add-vote-btn href="javascript:void(0)" Add Vote
        .item
          span#copy-public-link data-clipboard-text=board_post_url(@board, @post, host: @board.company.host)
            | Copy Public Link

coffee:
  $(".top-bar-more-options").dropdown({
    action: "nothing"
  })

  clipboard = new Clipboard("#copy-public-link")
  clipboard.on 'success', (e) ->
    copy_btn = $("#copy-public-link")
    copy_btn.html("Copied!")

    setTimeout (->
      copy_btn.html("Copy Public Link")
    ), 3000

