doctype html
html
  head
    meta[http-equiv="Content-Type" content="text/html; charset=utf-8"]
    style
      | body { max-width:600px; margin:10; padding: 0; font-family: sans-serif; font-size:15px; font-style: normal; line-height: 1.5; }

      | blockquote {
          color: #888888;
          margin: 0;
          padding: 4px 24px;
          border-left: 2px solid #e4e4e4;
        }

      | .comment {
          background: #f8f8f8;
          border: 1px solid #d6d6d6;
          padding: 1em 1em;
          border-radius: 5px;
        }

      | .note {
          background: #fff9ea;
          border: 1px solid #EADBC8;
          padding: 1em 1em;
          border-radius: 5px;
        }

      | .soft {
          color: #888888;
        }

      | .status {
          position: relative;
          color: #fff;
          border-radius: 50px;
          padding: 2px 8px;
          font-size: 14px;
          font-weight: 500;
          line-height: 19px;
          display: inline-block;
        }

      | .status.released {
          background: #5fba7d;
        }

      | .status.developing {
          background: #4a90e2;
        }

      | .status.planned {
          background: #7963BF;
        }

      | .status.closed {
          background: #c33c54;
        }

      | .status.open {
          color:  #7f7f7f;
          border: 1px solid #d6d6d6;
        }
        
      | a.button {
          color: #fff;
          background-color: #5fba7d;
          padding: 8px 16px;
          font-weight: 600;
          font-size: 16px;
          border-radius: 5px;
          text-decoration: none;
        }

      | ul.simple-list {
          list-style: none;
          padding: 0;
        }

      | ul.simple-list li {
          padding: 8px 0;
        }

      | a.link {
          color: #000;
          text-decoration: underline;
        }
  body
    = yield

    - unless @no_signatures
      p= @signature
