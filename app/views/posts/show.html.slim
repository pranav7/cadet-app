.ui.container
  .ui.grid
    .row
      .sixteen.wide.column
        .c-breadcrumb
          .section= link_to "Boards", boards_path
          .divider
              | /
          .section.active= link_to @board.name, board_path(@board)

    .row
      // Middle Section
      .ten.wide.column
        // Post Header
        .post-header.vertical-padded
          .header
            h1.post-title= @post.title
            .post-header-info
              strong.status class=@post.status ##{@post.status}
          .votes
            = render partial: "posts/vote", locals: { type: :large, post: @post }

        // Post Body
        = render partial: "partials/comment", locals: { resource: @post }

        // Create Comment
        = render partial: "comments/new",
          locals: { board: @board, post: @post, comment: @comment }

        // Post Activity
        .activity-header
          .text
            i.comments.outline.icon
            | Conversation
        - @post.comments.each do |comment|
          - next if comment.new_record?
          = render partial: "partials/comment", locals: { resource: comment }

      // Middle Section
      .six.wide.column
        // Voters
        = render partial: "partials/voters", locals: { voters: @post.voters }
        = render partial: "partials/cadet_power"
