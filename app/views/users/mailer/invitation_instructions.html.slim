p Hello #{@resource.first_name},

p We would like to invite you to Cadet - a tool we use to gather product feedback and feature requests. At #{@company.name}, we'd like to be transparent with our customers and this is a step in that direction.

p
  a.button href=accept_user_invitation_url(@resource, invitation_token: @token, host: @host) Accept Invite

p Here are our boards on Cadet -

ul.simple-list
  - @company.boards.non_private.each do |board|
    li
      strong
        a.link href=board_url(board, host: @host) #{board.name}
      br
      span.soft= board.description

  - if @resource.admin_of?(@company)
    - @company.boards.non_public.each do |board|
      li
        strong
          a.link href=board_url(board, host: @host) #{board.name} (Private)
        br
        span.soft= board.description

p Thank you for helping us make #{@company.name} awesome!

p
  | #{@invited_by.name}
  br
  | #{@company.name}
